# ============================================================
# Cloud SecureLens — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (Amazon Aurora PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cloud_secure_lens?schema=public&sslmode=require"

# --- NextAuth ---
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# --- Encryption key for sensitive DB fields (AES-256-GCM) ---
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key-here"

# --- AWS Credentials (use IAM role in production, never hardcode) ---
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# --- AWS Resource Names ---
AWS_CLOUDTRAIL_LOG_GROUP="/aws/cloudtrail/cloud-secure-lens"
AWS_RDS_CLUSTER_IDENTIFIER="cloud-secure-lens-aurora"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cloud SecureLens"
